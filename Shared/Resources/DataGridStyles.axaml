<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Standardized DataGrid Styles for RimSharp -->
    <!-- Consistent color scheme across all DataGrids -->
    
    <Style Selector="DataGrid">
        <Setter Property="Background" Value="{DynamicResource DataGridRowWhiteBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource RimworldBrownBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="GridLinesVisibility" Value="All"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource DataGridRowGrayBrush}"/>
        <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource DataGridGridLineBrush}"/>
        <Setter Property="RowBackground" Value="Transparent"/>
        <Setter Property="ScrollViewer.AllowAutoHide" Value="False"/>
        <Setter Property="FontSize" Value="12"/>
        <Style Selector="^ /template/ ScrollViewer /template/ ScrollContentPresenter#PART_ContentPresenter">
            <Setter Property="Grid.ColumnSpan" Value="1"/>
            <Setter Property="Grid.RowSpan" Value="1"/>
        </Style>
    </Style>

    <Style Selector="DataGridColumnHeader">
        <Setter Property="Background" Value="{DynamicResource RimworldLightBrownBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource RimworldWhiteBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="BorderBrush" Value="{DynamicResource RimworldBrownBrush}"/>
        <Setter Property="BorderThickness" Value="0,0,1,1"/>
        <Setter Property="Padding" Value="4,6"/>
        <Setter Property="SeparatorBrush" Value="{DynamicResource RimworldBrownBrush}"/>
        <Setter Property="Cursor" Value="Arrow"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="ClipToBounds" Value="False"/>
    </Style>

    <Style Selector="DataGridColumnHeader Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource RimworldWhiteBrush}"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="ClipToBounds" Value="False"/>
    </Style>

    <!-- Alternating row colors: white with gray -->
    <Style Selector="DataGridRow:nth-child(odd)">
        <Setter Property="Background" Value="{DynamicResource DataGridRowWhiteBrush}"/>
    </Style>

    <Style Selector="DataGridRow:nth-child(even)">
        <Setter Property="Background" Value="{DynamicResource DataGridRowGrayBrush}"/>
    </Style>

    <Style Selector="DataGridRow">
        <Setter Property="FontSize" Value="12"/>
        <Style Selector="^:selected /template/ Rectangle#Background">
            <Setter Property="Fill" Value="{DynamicResource RimworldHighlightBrush}"/>
            <Setter Property="Opacity" Value="0.3"/>
        </Style>
        <Style Selector="^:pointerover /template/ Rectangle#Background">
            <Setter Property="Fill" Value="{DynamicResource RimworldHighlightBrush}"/>
            <Setter Property="Opacity" Value="0.1"/>
        </Style>
    </Style>

    <Style Selector="DataGridCell">
        <Setter Property="Padding" Value="4,4"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="{DynamicResource RimworldBlackBrush}"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="ClipToBounds" Value="False"/>
        <Style Selector="^:selected /template/ Grid#FocusVisual">
            <Setter Property="IsVisible" Value="False"/>
        </Style>
    </Style>

    <!-- Standardized RowDetails Border Style -->
    <Style Selector="Border.DataGridRowDetails">
        <Setter Property="Background" Value="{DynamicResource DataGridRowGrayBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource DataGridGridLineBrush}"/>
        <Setter Property="BorderThickness" Value="0,1,0,1"/>
        <Setter Property="Padding" Value="15,10"/>
    </Style>

    <!-- Standardized RowDetails Separator Style -->
    <Style Selector="Separator.DataGridRowDetails">
        <Setter Property="Background" Value="{DynamicResource DataGridGridLineBrush}"/>
        <Setter Property="Opacity" Value="0.5"/>
        <Setter Property="Margin" Value="0,5"/>
    </Style>

    <!-- DataGridTextColumn Cell Style to prevent content overflow -->
    <Style Selector="DataGridCell TextBlock">
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        <Setter Property="TextWrapping" Value="NoWrap"/>
    </Style>

</Styles>
