<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:RimSharp.Features.WorkshopDownloader.Components.Browser"
             x:Class="RimSharp.Features.WorkshopDownloader.Components.Browser.BrowserView"
             x:DataType="vm:BrowserViewModel"
             mc:Ignorable="d">

    <UserControl.Styles>
        <Style Selector="Button.SearchIconButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource RimworldBrownBrush}"/>
            <Setter Property="Padding" Value="4,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">
        <!-- Navigation Bar -->
        <Border Grid.Row="0" Classes="RimworldInfoHeaderBorder" Padding="5,3">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto,170">
                <!-- Navigation Buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="2">
                     <Button Command="{Binding GoBackCommand}" Classes="BrowserNavButtonStyle" ToolTip.Tip="Back" Content="◄" FontSize="12"/>
                     <Button Command="{Binding GoForwardCommand}" Classes="BrowserNavButtonStyle" ToolTip.Tip="Forward" Content="►" FontSize="12"/>
                     <Button Command="{Binding GoHomeCommand}" Classes="BrowserNavButtonStyle" ToolTip.Tip="Home" Content="⌂" FontSize="12"/>
                </StackPanel>

                <!-- Refresh Button -->
                <Button Grid.Column="1" Command="{Binding RefreshCommand}" Classes="BrowserNavButtonStyle" ToolTip.Tip="Refresh" Content="↻" FontSize="12" Margin="5,0"/>

                <!-- Address Bar -->
                <Border Grid.Column="2" Background="{DynamicResource RimworldBeigeBrush}" BorderBrush="{DynamicResource RimworldBrownBrush}" BorderThickness="1" CornerRadius="3" VerticalAlignment="Center" Height="26">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Grid.Column="0" Text="🔒" Margin="5,0,2,0" VerticalAlignment="Center" Foreground="{DynamicResource RimworldDarkGreenBrush}" FontSize="10" IsVisible="{Binding IsSecure}"/>
                        <TextBox x:Name="AddressTextBox" Grid.Column="1" Text="{Binding AddressBarUrl}" VerticalContentAlignment="Center" Padding="5,0" BorderThickness="0" Background="Transparent" Foreground="{DynamicResource RimworldBrownBrush}" FontSize="12"
                                 KeyDown="AddressTextBox_KeyDown"/>
                        <TextBlock Grid.Column="2" Text="⏳" FontSize="10" Foreground="{DynamicResource RimworldBrownBrush}" Margin="2,0,5,0" VerticalAlignment="Center" IsVisible="{Binding IsLoading}"/>
                    </Grid>
                </Border>

                <!-- Separator -->
                 <Border Grid.Column="3" Width="1" Background="{DynamicResource RimworldLightBrownBrush}" Margin="5,0" VerticalAlignment="Stretch"/>

                <!-- Search Box -->
                <Border Grid.Column="4" Background="{DynamicResource RimworldBeigeBrush}" BorderBrush="{DynamicResource RimworldBrownBrush}" BorderThickness="1" CornerRadius="3" VerticalAlignment="Center" Height="26" Margin="0,0,5,0">
                    <Grid ColumnDefinitions="*,Auto">
                         <TextBox x:Name="SearchTextBox" Grid.Column="0" Text="{Binding SearchText}" Watermark="Search Workshop..." VerticalContentAlignment="Center" Padding="5,0,0,0" BorderThickness="0" Background="Transparent" Foreground="{DynamicResource RimworldBrownBrush}" FontSize="12"
                                  KeyDown="SearchTextBox_KeyDown"/>
                         <Button Grid.Column="1" Command="{Binding SearchCommand}" Content="🔍" FontSize="12" Classes="SearchIconButton" ToolTip.Tip="Search Steam Workshop"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Browser Control Container -->
        <Border Grid.Row="1" BorderBrush="{DynamicResource RimworldBrownBrush}" BorderThickness="0,1,0,1">
            <ContentControl x:Name="BrowserContainer" />
        </Border>
    </Grid>
</UserControl>
