<dialogs:BaseDialog xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:dialogs="clr-namespace:RimSharp.Infrastructure.Dialog"
                    xmlns:vm="clr-namespace:RimSharp.Features.WorkshopDownloader.Dialogs.Collection"
                    x:Class="RimSharp.Features.WorkshopDownloader.Dialogs.Collection.CollectionDialogView"
                    x:DataType="vm:CollectionDialogViewModel"
                    mc:Ignorable="d"
                    Title="{Binding Title}"
                    Width="600" Height="500" MinWidth="450" MinHeight="350">

    <dialogs:BaseDialog.MainContent>
        <DockPanel Margin="5">
            <!-- Top Buttons -->
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10" Spacing="5">
                <Button Content="Select All" Command="{Binding SelectAllCommand}" Classes="RimworldButtonStyle"/>
                <Button Content="Select None" Command="{Binding SelectNoneCommand}" Classes="RimworldButtonStyle"/>
            </StackPanel>

            <!-- Item List -->
            <DataGrid ItemsSource="{Binding Items}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="All"
                      BorderThickness="1"
                      BorderBrush="{DynamicResource RimworldBrownBrush}">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="40">
                        <DataGridTemplateColumn.Header>
                            <CheckBox IsEnabled="False" IsChecked="True"/>
                        </DataGridTemplateColumn.Header>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected}" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="250"/>
                    <DataGridTextColumn Header="Author" Binding="{Binding Author}" Width="150"/>
                    <DataGridTextColumn Header="Steam ID" Binding="{Binding SteamId}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </dialogs:BaseDialog.MainContent>

    <dialogs:BaseDialog.ButtonContent>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0" Spacing="10">
            <Button Content="Add Selected" Command="{Binding AddSelectedCommand}" Classes="RimworldSaveButtonStyle" MinWidth="100"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}" Classes="RimworldRunButtonStyle" MinWidth="100"/>
        </StackPanel>
    </dialogs:BaseDialog.ButtonContent>
</dialogs:BaseDialog>
