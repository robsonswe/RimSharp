<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:RimSharp.Features.ModManager.ViewModels.Actions"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             x:Class="RimSharp.Features.ModManager.Components.ModActions.ModActionsView"
             mc:Ignorable="d"
             x:DataType="vm:ModActionsViewModel"
             x:CompileBindings="True"
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid ColumnDefinitions="*,Auto">

        <!-- Left: Management Actions -->
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
            <Button Content="Clear" Command="{Binding ClearActiveListCommand}" Classes="RimworldButtonStyle" MinWidth="60"/>
            <Button Command="{Binding SortActiveListCommand}" Classes="RimworldButtonStyle" MinWidth="60">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="Sort"/>
                    <Border Background="{DynamicResource RimworldErrorRedBrush}" 
                            CornerRadius="10" Padding="5,0" VerticalAlignment="Center"
                            IsVisible="{Binding ActiveSortingIssuesCount, Converter={StaticResource NumericToBooleanConverter}}">
                        <TextBlock Text="{Binding ActiveSortingIssuesCount}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </Button>

            <Border Width="1" Height="16" Background="{DynamicResource RimworldBrownBrush}" Margin="8,0" VerticalAlignment="Center" Opacity="0.3"/>

            <Menu Background="Transparent" VerticalAlignment="Center">
                <MenuItem Classes="RimworldDropDownButtonStyle">
                    <MenuItem.Header>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="Maintenance"/>
                            <Border Background="{DynamicResource RimworldErrorRedBrush}" 
                                    CornerRadius="10" Padding="5,0" VerticalAlignment="Center"
                                    IsVisible="{Binding TotalActiveIssues, Converter={StaticResource NumericToBooleanConverter}}">
                                <TextBlock Text="{Binding TotalActiveIssues}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </MenuItem.Header>
                    <MenuItem Command="{Binding ResolveDependenciesCommand}" Classes="RimworldMenuItemStyle">
                        <MenuItem.Header>
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                    <i:Icon Value="fa-box" VerticalAlignment="Center" FontSize="12"/>
                                    <TextBlock Text="Dependencies" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="{DynamicResource RimworldErrorRedBrush}" 
                                        CornerRadius="10" Padding="5,0" VerticalAlignment="Center" Margin="10,0,0,0"
                                        IsVisible="{Binding ActiveMissingDependenciesCount, Converter={StaticResource NumericToBooleanConverter}}">
                                    <TextBlock Text="{Binding ActiveMissingDependenciesCount}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </MenuItem.Header>
                    </MenuItem>
                    <MenuItem Command="{Binding CheckIncompatibilitiesCommand}" Classes="RimworldMenuItemStyle">
                        <MenuItem.Header>
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                    <i:Icon Value="fa-ban" VerticalAlignment="Center" FontSize="12"/>
                                    <TextBlock Text="Incompatibilities" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="{DynamicResource RimworldErrorRedBrush}" 
                                        CornerRadius="10" Padding="5,0" VerticalAlignment="Center" Margin="10,0,0,0"
                                        IsVisible="{Binding ActiveIncompatibilitiesCount, Converter={StaticResource NumericToBooleanConverter}}">
                                    <TextBlock Text="{Binding ActiveIncompatibilitiesCount}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </MenuItem.Header>
                    </MenuItem>
                    <MenuItem Command="{Binding CheckDuplicatesCommand}" Classes="RimworldMenuItemStyle">
                        <MenuItem.Header>
                            <Grid ColumnDefinitions="*,Auto">
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                    <i:Icon Value="fa-clone" VerticalAlignment="Center" FontSize="12"/>
                                    <TextBlock Text="Duplicates" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="{DynamicResource RimworldErrorRedBrush}" 
                                        CornerRadius="10" Padding="5,0" VerticalAlignment="Center" Margin="10,0,0,0"
                                        IsVisible="{Binding ActiveDuplicateIssuesCount, Converter={StaticResource NumericToBooleanConverter}}">
                                    <TextBlock Text="{Binding ActiveDuplicateIssuesCount}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </Grid>
                        </MenuItem.Header>
                    </MenuItem>
                    <MenuItem Command="{Binding CheckReplacementsCommand}" Classes="RimworldMenuItemStyle">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <i:Icon Value="fa-arrows-rotate" VerticalAlignment="Center" FontSize="12"/>
                                <TextBlock Text="Replacements" VerticalAlignment="Center"/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                </MenuItem>
            </Menu>

            <Menu Background="Transparent" VerticalAlignment="Center">
                <MenuItem Header="Utilities" Classes="RimworldDropDownButtonStyle">
                    <MenuItem Command="{Binding StripModsCommand}" Classes="RimworldMenuItemStyle">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <i:Icon Value="fa-scissors" VerticalAlignment="Center" FontSize="12"/>
                                <TextBlock Text="Strip mods" VerticalAlignment="Center"/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                    <MenuItem Command="{Binding FixIntegrityCommand}" Classes="RimworldMenuItemStyle">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <i:Icon Value="fa-hammer" VerticalAlignment="Center" FontSize="12"/>
                                <TextBlock Text="Fix integrity" VerticalAlignment="Center"/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                    <Separator Classes="RimworldSeparatorStyle"/>
                    <MenuItem Command="{Binding InstallFromZipCommand}" Classes="RimworldMenuItemStyle">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <i:Icon Value="fa-box" VerticalAlignment="Center" FontSize="12"/>
                                <TextBlock Text="Install From Zip" VerticalAlignment="Center"/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                    <MenuItem Command="{Binding InstallFromGithubCommand}" Classes="RimworldMenuItemStyle">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <i:Icon Value="fa-brands fa-github" VerticalAlignment="Center" FontSize="12"/>
                                <TextBlock Text="Install From Github" VerticalAlignment="Center"/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                </MenuItem>
            </Menu>
        </StackPanel>

        <!-- Right: IO Actions -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
            <Button Content="Import list" Command="{Binding ImportListCommand}" Classes="RimworldButtonStyle" MinWidth="90"/>
            <Button Content="Export list" Command="{Binding ExportListCommand}" Classes="RimworldButtonStyle" MinWidth="90"/>

            <Border Width="1" Height="16" Background="{DynamicResource RimworldBrownBrush}" Margin="8,0" VerticalAlignment="Center" Opacity="0.3"/>

            <Button Content="Save" Command="{Binding SaveCommand}" Classes="RimworldSaveButtonStyle" MinWidth="80"/>
            <Button Content="Run" Command="{Binding RunGameCommand}" Classes="RimworldRunButtonStyle" MinWidth="80"/>
        </StackPanel>
    </Grid>
</UserControl>
