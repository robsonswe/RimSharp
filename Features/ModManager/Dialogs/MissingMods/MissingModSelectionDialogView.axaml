<dialogs:BaseDialog xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:dialogs="clr-namespace:RimSharp.Infrastructure.Dialog"
        xmlns:vm="clr-namespace:RimSharp.Features.ModManager.Dialogs.MissingMods"
        x:Class="RimSharp.Features.ModManager.Dialogs.MissingMods.MissingModSelectionDialogView"
        x:DataType="vm:MissingModSelectionDialogViewModel"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Width="750" MinWidth="650" MaxWidth="1000"
        Height="600" MinHeight="450" MaxHeight="800"
        WindowStartupLocation="CenterOwner">

    <dialogs:BaseDialog.MainContent>
        <Grid Margin="15" RowDefinitions="Auto,*">
            <TextBlock Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,15" Foreground="{DynamicResource RimworldDarkBrownBrush}">
                The following mods from the imported list were not found locally or need clarification:
                - Select a variant for mods found in the database to enable download.
                - Unavailable variants (not on Workshop) cannot be selected.
                - Mods marked 'Not found' cannot be downloaded automatically.
            </TextBlock>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="10">
                    <ItemsControl ItemsSource="{Binding ModGroups}" IsVisible="{Binding HasKnownMods}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:MissingModGroupViewModel">
                                <Expander Header="{Binding PackageId}" IsExpanded="True" Margin="0,5">
                                    <ListBox ItemsSource="{Binding Variants}" SelectedItem="{Binding SelectedVariant}" Background="Transparent" BorderThickness="0">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate x:DataType="vm:MissingModVariantViewModel">
                                                <Border Padding="8,5" BorderBrush="{DynamicResource RimworldBrownBrush}" BorderThickness="0,0,0,1">
                                                    <Grid ColumnDefinitions="Auto,*">
                                                        <RadioButton Grid.Column="0" IsChecked="{Binding IsSelected}" IsEnabled="{Binding IsSelectable}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                        <StackPanel Grid.Column="1" Spacing="2">
                                                            <TextBlock FontWeight="SemiBold" Text="{Binding Name}" Foreground="{DynamicResource RimworldDarkBrownBrush}" TextWrapping="Wrap"/>
                                                            <TextBlock Text="(Unpublished)" Foreground="{DynamicResource RimworldLightBrownBrush}" FontStyle="Italic" FontSize="11" IsVisible="{Binding !IsPublished}"/>
                                                            <TextBlock Text="{Binding Authors, StringFormat='Author(s): {0}'}" FontSize="11"/>
                                                            <TextBlock Text="{Binding VersionsString, StringFormat='Supported Versions: {0}'}" FontSize="11"/>
                                                            <TextBlock Text="{Binding SteamId, StringFormat='Steam ID: {0}'}" FontSize="11" FontStyle="Italic"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Separator Classes="RimworldSeparatorStyle" IsVisible="{Binding HasUnknownMods}"/>

                    <ItemsControl ItemsSource="{Binding UnknownModIds}" IsVisible="{Binding HasUnknownMods}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Classes="RimworldPanelBorder" Margin="0,5">
                                    <StackPanel Spacing="5">
                                        <TextBlock Text="{Binding}" FontWeight="SemiBold"/>
                                        <TextBlock Text="Not found in local database - Cannot be downloaded automatically." FontStyle="Italic" FontSize="11" Foreground="{DynamicResource RimworldLightBrownBrush}"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </dialogs:BaseDialog.MainContent>

    <dialogs:BaseDialog.ButtonContent>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="10">
            <Button Content="Download Selected" Command="{Binding DownloadCommand}" Classes="RimworldSaveButtonStyle" MinWidth="140"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}" Classes="RimworldRunButtonStyle" MinWidth="90"/>
        </StackPanel>
    </dialogs:BaseDialog.ButtonContent>
</dialogs:BaseDialog>
