<dialogs:BaseDialog xmlns="https://github.com/avaloniaui"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                  xmlns:local="clr-namespace:RimSharp.Features.ModManager.Dialogs.Incompatibilities"
                  xmlns:dialogs="clr-namespace:RimSharp.Infrastructure.Dialog"
                  x:Class="RimSharp.Features.ModManager.Dialogs.Incompatibilities.ModIncompatibilityDialogView"
                  x:DataType="local:ModIncompatibilityDialogViewModel"
                  mc:Ignorable="d"
                  Title="Resolve Mod Incompatibilities">

    <dialogs:BaseDialog.MainContent>
        <StackPanel Spacing="10">
            <TextBlock Text="Incompatible Mods Detected" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource RimworldDarkBrownBrush}"/>
            <TextBlock Text="Select which mod to keep in each incompatibility group." FontSize="13" TextWrapping="Wrap"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="600">
                <ItemsControl ItemsSource="{Binding IncompatibilityGroups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="local:IncompatibilityGroupViewModel">
                            <Border Classes="RimworldPanelBorder" Margin="0,0,0,15" Padding="0">
                                <StackPanel>
                                    <Border Background="{DynamicResource RimworldLightBrownBrush}" Padding="10,8">
                                        <TextBlock Text="Incompatibility Group" FontWeight="Bold" FontSize="14"/>
                                    </Border>
                                    <ItemsControl ItemsSource="{Binding ResolutionOptions}" Margin="10">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="local:IncompatibilityResolutionOption">
                                                <Border Margin="0,0,0,10" Padding="10" Background="{DynamicResource RimworldBeigeBrush}" CornerRadius="3" BorderThickness="1" BorderBrush="{DynamicResource RimworldBrownBrush}">
                                                    <RadioButton IsChecked="{Binding IsSelected}" GroupName="{Binding ParentGroup.GroupName}">
                                                        <StackPanel Spacing="5">
                                                            <Panel>
                                                                <TextBlock IsVisible="{Binding ModToKeep, Converter={StaticResource NullToVisibilityConverter}}" FontWeight="SemiBold" FontSize="13">
                                                                    <TextBlock.Text>
                                                                        <MultiBinding StringFormat="Keep: {0}">
                                                                            <Binding Path="ModToKeep.Name" FallbackValue="Unknown"/>
                                                                        </MultiBinding>
                                                                    </TextBlock.Text>
                                                                </TextBlock>
                                                                <TextBlock IsVisible="{Binding ModToKeep, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource RimworldDarkGreenBrush}" Text="Keep all mods (soft incompatibility)"/>
                                                            </Panel>
                                                            
                                                            <StackPanel Margin="20,0,0,0" IsVisible="{Binding ModsToRemove.Count}">
                                                                <TextBlock Text="Will remove the following mods:" FontSize="12"/>
                                                                                                                                    <ItemsControl ItemsSource="{Binding RemovalReasons}">
                                                                                                                                    <ItemsControl.ItemTemplate>
                                                                                                                                        <DataTemplate>
                                                                                                                                            <StackPanel Margin="0,5">
                                                                                                                                                <TextBlock FontWeight="Bold" Foreground="{DynamicResource RimworldRedBrush}" 
                                                                                                                                                           Text="{Binding Key.Name, FallbackValue='Unknown', TargetNullValue='Unknown'}"/>
                                                                                                                                                <ItemsControl ItemsSource="{Binding Value}" Margin="15,0,0,0">
                                                                
                                                                                    <ItemsControl.ItemTemplate>
                                                                                        <DataTemplate>
                                                                                            <TextBlock Text="{Binding Reason, StringFormat='• {0}'}" FontSize="11" TextWrapping="Wrap"/>
                                                                                        </DataTemplate>
                                                                                    </ItemsControl.ItemTemplate>
                                                                                </ItemsControl>
                                                                            </StackPanel>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </RadioButton>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>
    </dialogs:BaseDialog.MainContent>

    <dialogs:BaseDialog.ButtonContent>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
            <Button Content="Cancel" Command="{Binding CancelCommand}" IsEnabled="{Binding IsCancelEnabled}" Width="100" Classes="RimworldButtonStyle"/>
            <Button Content="Apply Changes" Command="{Binding ApplyResolutionsCommand}" Width="120" Classes="RimworldSaveButtonStyle"/>
        </StackPanel>
    </dialogs:BaseDialog.ButtonContent>
</dialogs:BaseDialog>
