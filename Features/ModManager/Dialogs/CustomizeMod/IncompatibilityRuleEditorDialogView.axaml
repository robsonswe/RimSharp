<dialogs:BaseDialog xmlns="https://github.com/avaloniaui"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:dialogs="clr-namespace:RimSharp.Infrastructure.Dialog"
                  xmlns:vm="clr-namespace:RimSharp.Features.ModManager.Dialogs.CustomizeMod"
                  x:Class="RimSharp.Features.ModManager.Dialogs.CustomizeMod.IncompatibilityRuleEditorDialogView"
                  x:DataType="vm:IncompatibilityRuleEditorDialogViewModel"
                  Width="480" Height="480" Title="{Binding Title}">

    <dialogs:BaseDialog.MainContent>
        <Border Classes="RimworldSubtlePanelBorder" Margin="10,10,10,5">
            <!-- Increased row spacing slightly -->
            <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,15,Auto,15,Auto,15,Auto" Margin="10">
                
                <!-- Package ID -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Package ID:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="*,Auto">
                    <TextBox Grid.Column="0" Text="{Binding PackageId}" Classes="RimworldTextBox" Watermark="e.g. ludeon.rimworld"/>
                    <Button Grid.Column="1" Content="Search" Command="{Binding OpenModSelectorCommand}" Margin="8,0,0,0" Classes="RimworldButtonStyle"/>
                </Grid>

                <!-- Display Name -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Display Name:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding DisplayName}" Classes="RimworldTextBox" Watermark="Optional display name"/>

                <!-- Comment -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Comment:" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Comment}" Classes="RimworldTextBox" Watermark="Optional reasoning"/>

                <!-- Hard Incompatibility Box -->
                <Border Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" 
                        Background="{DynamicResource RimworldBeigeBrush}" 
                        BorderBrush="{DynamicResource RimworldBrownBrush}" 
                        BorderThickness="1" Padding="12" CornerRadius="3" Margin="0,5,0,0">
                    <StackPanel Spacing="8">
                        <CheckBox Content="Hard Incompatibility" 
                                  IsChecked="{Binding HardIncompatibility}" 
                                  FontWeight="Bold" />
                        
                        <TextBlock Text="If checked, this marks a critical conflict. Running both mods together will break the game or cause major instability." 
                                   FontSize="11.5" TextWrapping="Wrap" Foreground="{DynamicResource RimworldDarkBrownBrush}"/>
                        
                        <TextBlock Text="Leave unchecked if the mods have conflicts (glitches, balance issues) but the game can still technically run (Soft Incompatibility)." 
                                   FontSize="11" TextWrapping="Wrap" FontStyle="Italic" Foreground="{DynamicResource RimworldLightBrownBrush}"/>
                    </StackPanel>
                </Border>
                
            </Grid>
        </Border>
    </dialogs:BaseDialog.MainContent>
    
    <dialogs:BaseDialog.ButtonContent>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,15,15">
            <Button Content="Save" Command="{Binding SaveCommand}" Classes="RimworldSaveButtonStyle"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}" Classes="RimworldButtonStyle"/>
        </StackPanel>
    </dialogs:BaseDialog.ButtonContent>
</dialogs:BaseDialog>