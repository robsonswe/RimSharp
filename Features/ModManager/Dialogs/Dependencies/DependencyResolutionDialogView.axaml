<dialogs:BaseDialog xmlns="https://github.com/avaloniaui"
                   xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                   xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                   xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                   xmlns:local="clr-namespace:RimSharp.Features.ModManager.Dialogs.Dependencies"
                   xmlns:dialogs="clr-namespace:RimSharp.Infrastructure.Dialog"
                   x:Class="RimSharp.Features.ModManager.Dialogs.Dependencies.DependencyResolutionDialogView"
                   x:DataType="local:DependencyResolutionDialogViewModel"
                   mc:Ignorable="d"
                   Title="{Binding Title}"
                   Width="750" MinHeight="450" MaxHeight="700">

    <dialogs:BaseDialog.MainContent>
        <Grid Margin="10" RowDefinitions="Auto,*,Auto">
            <!-- Header -->
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                <TextBlock Grid.Column="0" VerticalAlignment="Center" TextWrapping="Wrap">
                    The following mods are required by mods in your active list but are missing.
                    Select the dependencies you wish to download from the Steam Workshop:
                </TextBlock>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="5">
                    <Button Content="Select All" Command="{Binding SelectAllCommand}" Classes="RimworldButtonStyle"/>
                    <Button Content="Select None" Command="{Binding SelectNoneCommand}" Classes="RimworldButtonStyle"/>
                </StackPanel>
            </Grid>

            <!-- List of Missing Dependencies -->
            <ListBox Grid.Row="1" ItemsSource="{Binding MissingDependencies}" Classes="RimworldListBox" SelectionMode="Multiple">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="local:MissingDependencyItemViewModel">
                        <Border Padding="5" Margin="2" BorderBrush="{DynamicResource RimworldBrownBrush}" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="Auto,*">
                                <!-- Checkbox -->
                                <CheckBox Grid.Column="0" VerticalAlignment="Top" Margin="0,2,10,0" IsChecked="{Binding IsSelected}" IsEnabled="{Binding IsSelectable}"/>

                                <!-- Dependency Details -->
                                <StackPanel Grid.Column="1">
                                    <TextBlock FontWeight="Medium">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} ({1})">
                                                <Binding Path="DisplayName" FallbackValue="Unknown"/>
                                                <Binding Path="PackageId" FallbackValue="Unknown"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>

                                    <StackPanel Orientation="Horizontal" Spacing="5" IsVisible="{Binding IsSelectable}">
                                        <TextBlock Text="Steam: " FontSize="10" Foreground="Gray"/>
                                        <Button Content="{Binding SteamId}" 
                                                Command="{Binding $parent[Window].DataContext.OpenUrlCommand}"
                                                CommandParameter="{Binding SteamWorkshopUrl}"
                                                Background="Transparent" BorderThickness="0" Padding="0"
                                                Foreground="{DynamicResource RimworldDarkGreenBrush}" FontSize="10"/>
                                    </StackPanel>
                                    
                                    <TextBlock IsVisible="{Binding !IsSelectable}" FontSize="10" Foreground="{DynamicResource RimworldRedBrush}" Text="No Steam Workshop link found"/>

                                    <Expander Header="Required By:" Margin="0,5,0,0">
                                         <ItemsControl ItemsSource="{Binding RequiredByDisplay}">
                                             <ItemsControl.ItemTemplate>
                                                 <DataTemplate>
                                                     <TextBlock Text="{Binding}" Margin="0,1" FontSize="11" Foreground="DimGray"/>
                                                 </DataTemplate>
                                             </ItemsControl.ItemTemplate>
                                         </ItemsControl>
                                    </Expander>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Footer -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0" Spacing="10">
                <TextBlock Text="{Binding SelectedCount, StringFormat='{}{0} dependencies selected'}" VerticalAlignment="Center"/>
                <Button Content="Cancel" Command="{Binding CloseWithResultCommand}" CommandParameter="{x:Static local:DependencyResolutionDialogResult.Cancel}" Classes="RimworldButtonStyle"/>
                <Button Content="Download Selected" Command="{Binding CloseWithResultCommand}" CommandParameter="{x:Static local:DependencyResolutionDialogResult.Download}" Classes="RimworldButtonStyle" IsEnabled="{Binding SelectedCount}"/>
            </StackPanel>
        </Grid>
    </dialogs:BaseDialog.MainContent>
</dialogs:BaseDialog>
